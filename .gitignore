*.idx
*.ind
*.ilg
*.bcf
*.run.xml

# --- Logs / temp ---
*.tmp
*.swp
*~

# NOTE: PDF files are intentionally NOT ignored.
# The project statement PDF and the final report/presentation PDFs
# must remain tracked in the repository (required for submission).
